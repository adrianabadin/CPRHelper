<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AclsTracker.Models"
             x:Class="AclsTracker.Views.HistorialPage"
             Title="Historial">
    <CollectionView ItemsSource="{Binding Events}" Margin="16">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="models:EventRecord">
                <Grid ColumnDefinitions="Auto, Auto, *" Padding="0,4">
                    <Label Grid.Column="0"
                           Text="{Binding ElapsedSinceStart, StringFormat='{0:mm\\:ss}'}"
                           FontSize="12" TextColor="#999999" MinimumWidthRequest="50" />
                    <Label Grid.Column="1"
                           Text="{Binding EventType}"
                           FontSize="11" TextColor="#1565C0"
                           MinimumWidthRequest="80" Margin="4,0" />
                    <Label Grid.Column="2"
                           Text="{Binding Description}"
                           FontSize="13" />
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.EmptyView>
            <Label Text="No hay eventos registrados en esta sesion."
                   HorizontalTextAlignment="Center"
                   VerticalTextAlignment="Center"
                   TextColor="#999999"
                   FontSize="14"
                   Margin="0,40" />
        </CollectionView.EmptyView>
    </CollectionView>
</ContentPage>
