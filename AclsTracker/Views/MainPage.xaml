<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AclsTracker.Controls"
             xmlns:vm="clr-namespace:AclsTracker.ViewModels"
             xmlns:converters="clr-namespace:AclsTracker.Converters"
             x:Class="AclsTracker.Views.MainPage"
             x:Name="MainPageControl"
             Title="Principal"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="10" Spacing="6">

            <!-- BLOCK 1: INICIAR / FINALIZAR CODIGO -->
            <Grid HorizontalOptions="Fill">
                <Button Text="INICIAR CODIGO"
                        Command="{Binding StartCodeCommand}"
                        BackgroundColor="#E65100"
                        TextColor="White"
                        FontSize="16" FontAttributes="Bold"
                        HeightRequest="40"
                        CornerRadius="8"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding Timer.IsSessionActive, Converter={StaticResource InvertBoolConverter}}" />
                <Button Text="FINALIZAR CODIGO"
                        Command="{Binding StopCodeCommand}"
                        BackgroundColor="#757575"
                        TextColor="White"
                        FontSize="16" FontAttributes="Bold"
                        HeightRequest="40"
                        CornerRadius="8"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding Timer.IsSessionActive}" />
            </Grid>

            <!-- BLOCK 2: Metronomo compacto horizontal -->
            <controls:MetronomePulse IsPulsing="{Binding BeatPulse}"
                                     BindingContext="{Binding Metronome}" />

            <!-- BLOCK 3: Selector de ritmo -->
            <controls:RhythmSelector BindingContext="{Binding EventRecording}" />

            <!-- BLOCK 4: Grid de 6 timers (2 columnas x 3 filas) -->
            <Grid ColumnDefinitions="*, *"
                  RowDefinitions="Auto, Auto, Auto"
                  ColumnSpacing="6" RowSpacing="6">
                <!-- [0] Tiempo Total -->
                <controls:TimerCard Grid.Row="0" Grid.Column="0"
                                    BindingContext="{Binding Timer.Timers[0]}" />
                <!-- [1] Ciclo RCP -->
                <controls:TimerCard Grid.Row="0" Grid.Column="1"
                                    BindingContext="{Binding Timer.Timers[1]}" />
                <!-- [2] Compresiones — with pause button -->
                <controls:TimerCard Grid.Row="1" Grid.Column="0"
                                    BindingContext="{Binding Timer.Timers[2]}"
                                    ShowPauseButton="True"
                                    PauseCommand="{Binding TogglePauseCommand, Source={x:Reference MainPageControl}}" />
                <!-- [3] Adrenalina -->
                <controls:TimerCard Grid.Row="1" Grid.Column="1"
                                    BindingContext="{Binding Timer.Timers[3]}" />
                <!-- [4] Amiodarona -->
                <controls:TimerCard Grid.Row="2" Grid.Column="0"
                                    BindingContext="{Binding Timer.Timers[4]}" />
                <!-- [5] Tiempo entre pulsos (red > 10s via IsOverThreshold) -->
                <controls:TimerCard Grid.Row="2" Grid.Column="1"
                                    BindingContext="{Binding Timer.Timers[5]}" />
            </Grid>

            <!-- BLOCK 5: Botones de accion — 2 rows x 2 columns -->
            <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto"
                  ColumnSpacing="8" RowSpacing="6">
                <!-- Row 0: NUEVO CICLO + DEFIBRILAR -->
                <Button Grid.Row="0" Grid.Column="0"
                        Text="NUEVO CICLO"
                        Command="{Binding NewCycleCommand}"
                        BackgroundColor="#FF9800"
                        TextColor="White" FontSize="14" FontAttributes="Bold"
                        HeightRequest="40" CornerRadius="8" />
                <Button Grid.Row="0" Grid.Column="1"
                        x:Name="DefibrilarButton"
                        Text="DEFIBRILAR"
                        Command="{Binding DefibrilarCommand}"
                        BackgroundColor="#C62828"
                        TextColor="White" FontSize="14" FontAttributes="Bold"
                        HeightRequest="40" CornerRadius="8" />
                <!-- Row 1: ADRENALINA + AMIODARONA (DataTriggers preserved) -->
                <Button Grid.Row="1" Grid.Column="0"
                        Text="ADRENALINA"
                        Command="{Binding AdrenalinaCommand}"
                        BackgroundColor="#7B1FA2"
                        TextColor="White" FontSize="14" FontAttributes="Bold"
                        HeightRequest="40" CornerRadius="8">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsAdrenalinaSuggested}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#D32F2F" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <Button Grid.Row="1" Grid.Column="1"
                        Text="AMIODARONA"
                        Command="{Binding AmiodaronaCommand}"
                        IsEnabled="{Binding IsAmiodaronaEnabled}"
                        Opacity="{Binding IsAmiodaronaEnabled, Converter={StaticResource BoolToOpacityConverter}}"
                        BackgroundColor="#7B1FA2"
                        TextColor="White" FontSize="14" FontAttributes="Bold"
                        HeightRequest="40" CornerRadius="8">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsAmiodaronaSuggested}"
                                     Value="True">
                            <Setter Property="BackgroundColor" Value="#D32F2F" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
            </Grid>

            <!-- BLOCK 6: EventLog below the fold (scrollable within page scroll) -->
            <controls:EventLogPanel BindingContext="{Binding EventRecording}" />

        </VerticalStackLayout>
        </ScrollView>

        <!-- Notification banner (top, overlays content) -->
        <controls:NotificationBanner x:Name="BannerControl"
                                     VerticalOptions="Start"
                                     ZIndex="10" />
    </Grid>
</ContentPage>
