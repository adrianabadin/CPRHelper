<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AclsTracker.ViewModels"
             xmlns:converters="clr-namespace:AclsTracker.Converters"
             x:Class="AclsTracker.Views.LoginPage"
             Title="Iniciar Sesion"
             BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">

            <!-- Title -->
            <Label Text="Iniciar Sesion"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20" />

            <!-- Google Sign-In Button -->
            <Button x:Name="GoogleButton"
                    Text="Continuar con Google"
                    Command="{Binding SignInWithGoogleCommand}"
                    IsVisible="{Binding IsGoogleAvailable}"
                    BackgroundColor="#4285F4"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="25"
                    HorizontalOptions="Fill" />

            <!-- Apple Sign-In Button -->
            <Button x:Name="AppleButton"
                    Text="Continuar con Apple"
                    Command="{Binding SignInWithAppleCommand}"
                    IsVisible="{Binding IsAppleAvailable}"
                    BackgroundColor="Black"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="25"
                    HorizontalOptions="Fill" />

            <!-- Separator -->
            <Grid ColumnDefinitions="*,Auto,*" Margin="0,10">
                <BoxView Grid.Column="0" Color="Gray" HeightRequest="1" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="o" FontSize="14" TextColor="Gray" Margin="10,0" VerticalOptions="Center" />
                <BoxView Grid.Column="2" Color="Gray" HeightRequest="1" VerticalOptions="Center" />
            </Grid>

            <!-- Email Entry -->
            <Entry Placeholder="Email"
                   Text="{Binding Email}"
                   Keyboard="Email"
                   FontSize="16"
                   HeightRequest="50" />

            <!-- Password Entry -->
            <Entry Placeholder="Contrasena"
                   Text="{Binding Password}"
                   IsPassword="true"
                   FontSize="16"
                   HeightRequest="50" />

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red"
                   FontSize="14"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                   Margin="0,0,0,5" />

            <!-- Sign In Button -->
            <Button Text="Iniciar Sesion"
                    Command="{Binding SignInWithEmailCommand}"
                    BackgroundColor="#1976D2"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    HeightRequest="50"
                    CornerRadius="25"
                    HorizontalOptions="Fill" />

            <!-- Forgot Password Link -->
            <Label Text="Olvidaste tu contrasena?"
                   TextColor="#1976D2"
                   FontSize="14"
                   HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ResetPasswordCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Register Link -->
            <Label Text="No tienes cuenta? Registrate"
                   TextColor="#1976D2"
                   FontSize="14"
                   HorizontalOptions="Center"
                   Margin="0,10,0,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateToRegisterCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Activity Indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#1976D2"
                               HorizontalOptions="Center"
                               Margin="0,10,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
