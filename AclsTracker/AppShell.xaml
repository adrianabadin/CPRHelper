<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AclsTracker.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:AclsTracker.Views"
    xmlns:controls="clr-namespace:AclsTracker.Controls"
    Shell.FlyoutBehavior="Disabled">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="10,0">
            <Label Grid.Column="0"
                   Text="CPR Assistant"
                   TextColor="White"
                   FontSize="18"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            <controls:AuthAvatarControl Grid.Column="1"
                                        x:Name="authAvatar"
                                        VerticalOptions="Center" />
        </Grid>
    </Shell.TitleView>

    <TabBar>
        <Tab Title="Principal">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage" />
        </Tab>
        <Tab Title="Causas Reversibles">
            <ShellContent ContentTemplate="{DataTemplate views:HsAndTsPage}" Route="HsAndTsPage" />
        </Tab>
        <Tab Title="Historial">
            <ShellContent ContentTemplate="{DataTemplate views:HistorialPage}" Route="HistorialPage" />
        </Tab>
    </TabBar>

</Shell>
