<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AclsTracker.Models"
             x:Class="AclsTracker.Controls.RhythmSelector">

    <VerticalStackLayout Spacing="8">

        <!-- Section header -->
        <Label Text="RITMO CARDÍACO"
               FontSize="12"
               FontAttributes="Bold"
               TextColor="#999999"
               HorizontalTextAlignment="Center"
               CharacterSpacing="1" />

        <!-- Current rhythm display -->
        <Label Text="{Binding CurrentRhythmDisplay, StringFormat='Ritmo actual: {0}'}"
               FontSize="14"
               FontAttributes="Bold"
               HorizontalTextAlignment="Center"
               TextColor="#333333" />

        <!-- Rhythm buttons — FlexLayout wraps on small screens -->
        <FlexLayout Wrap="Wrap"
                    JustifyContent="Center"
                    AlignItems="Center">

            <!-- RCE (Retorno de Circulacion Espontanea) — green -->
            <Button Text="RCE"
                    Command="{Binding SelectRhythmCommand}"
                    CommandParameter="{x:Static models:CardiacRhythm.RCE}"
                    BackgroundColor="#2E7D32"
                    TextColor="White" FontSize="14" FontAttributes="Bold"
                    MinimumWidthRequest="80" HeightRequest="44" CornerRadius="8" Margin="4" />

            <!-- AESP (Actividad Electrica Sin Pulso) — non-shockable, orange -->
            <Button Text="AESP"
                    Command="{Binding SelectRhythmCommand}"
                    CommandParameter="{x:Static models:CardiacRhythm.AESP}"
                    BackgroundColor="#E65100"
                    TextColor="White" FontSize="14" FontAttributes="Bold"
                    MinimumWidthRequest="80" HeightRequest="44" CornerRadius="8" Margin="4" />

            <!-- ASISTOLIA — non-shockable, orange -->
            <Button Text="ASISTOLIA"
                    Command="{Binding SelectRhythmCommand}"
                    CommandParameter="{x:Static models:CardiacRhythm.Asistolia}"
                    BackgroundColor="#E65100"
                    TextColor="White" FontSize="14" FontAttributes="Bold"
                    MinimumWidthRequest="80" HeightRequest="44" CornerRadius="8" Margin="4" />

            <!-- TV (Taquicardia Ventricular sin pulso) — shockable, red -->
            <Button Text="TV"
                    Command="{Binding SelectRhythmCommand}"
                    CommandParameter="{x:Static models:CardiacRhythm.TV}"
                    BackgroundColor="#D32F2F"
                    TextColor="White" FontSize="14" FontAttributes="Bold"
                    MinimumWidthRequest="80" HeightRequest="44" CornerRadius="8" Margin="4" />

            <!-- FV (Fibrilacion Ventricular) — shockable, red -->
            <Button Text="FV"
                    Command="{Binding SelectRhythmCommand}"
                    CommandParameter="{x:Static models:CardiacRhythm.FV}"
                    BackgroundColor="#D32F2F"
                    TextColor="White" FontSize="14" FontAttributes="Bold"
                    MinimumWidthRequest="80" HeightRequest="44" CornerRadius="8" Margin="4" />

        </FlexLayout>
    </VerticalStackLayout>

</ContentView>
