<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AclsTracker.Controls.MetronomePulse"
             x:Name="PulseControl">
    <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center" Padding="8,4">
        <!-- Pulse circle — color flash animation on each beat -->
        <Grid WidthRequest="45" HeightRequest="45" BackgroundColor="Transparent">
            <BoxView x:Name="PulseCircle"
                     WidthRequest="42" HeightRequest="42"
                     CornerRadius="21"
                     Color="#D32F2F"
                     BackgroundColor="Transparent"
                     HorizontalOptions="Center"
                     VerticalOptions="Center" />
        </Grid>
        <!-- BPM large label -->
        <Label Text="{Binding Bpm}"
               FontSize="30"
               FontAttributes="Bold"
               VerticalOptions="Center"
               TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
               MinimumWidthRequest="40" />
        <Label Text="BPM"
               FontSize="12"
               VerticalOptions="End"
               TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
               Margin="0,0,8,6" />
        <!-- Controls: -, ON/STOP, + -->
        <Button Text="&#x2212;"
                Command="{Binding DecreaseBpmCommand}"
                FontSize="18"
                WidthRequest="36" HeightRequest="36"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                Padding="0" />
        <Button x:Name="ToggleBtn"
                Text="{Binding IsPlaying, Converter={StaticResource BoolToOnOffConverter}}"
                Command="{Binding ToggleMetronomeCommand}"
                FontSize="14" FontAttributes="Bold"
                WidthRequest="56" HeightRequest="36"
                CornerRadius="8"
                BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                TextColor="White"
                Padding="0" />
        <Button Text="+"
                Command="{Binding IncreaseBpmCommand}"
                FontSize="18"
                WidthRequest="36" HeightRequest="36"
                CornerRadius="18"
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                Padding="0" />
    </HorizontalStackLayout>
</ContentView>
