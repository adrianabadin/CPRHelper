<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AclsTracker.Controls.MetronomePulse"
             x:Name="PulseControl">
    <HorizontalStackLayout Spacing="12" VerticalOptions="Center" HorizontalOptions="Center" Padding="8,4">
        <!-- Compact pulse circle 50px -->
        <Grid WidthRequest="50" HeightRequest="50">
            <Ellipse x:Name="PulseCircle"
                     WidthRequest="44" HeightRequest="44"
                     Fill="{StaticResource Primary}"
                     Opacity="0.8"
                     HorizontalOptions="Center"
                     VerticalOptions="Center" />
        </Grid>
        <!-- BPM large label -->
        <Label Text="{Binding Bpm}"
               FontSize="30"
               FontAttributes="Bold"
               VerticalOptions="Center"
               TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
               MinimumWidthRequest="40" />
        <Label Text="BPM"
               FontSize="12"
               VerticalOptions="End"
               TextColor="{AppThemeBinding Light=#666666, Dark=#999999}"
               Margin="0,0,8,6" />
        <!-- Controls: -, ON/STOP, + -->
        <Button Text="&#x2212;"
                Command="{Binding DecreaseBpmCommand}"
                FontSize="20"
                WidthRequest="44" HeightRequest="44"
                CornerRadius="22"
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                Padding="0" />
        <Button x:Name="ToggleBtn"
                Text="{Binding IsPlaying, StringFormat='{0}'}"
                Command="{Binding ToggleMetronomeCommand}"
                FontSize="14" FontAttributes="Bold"
                WidthRequest="70" HeightRequest="44"
                CornerRadius="8"
                BackgroundColor="{AppThemeBinding Light=#1976D2, Dark=#1565C0}"
                TextColor="White"
                Padding="0" />
        <Button Text="+"
                Command="{Binding IncreaseBpmCommand}"
                FontSize="20"
                WidthRequest="44" HeightRequest="44"
                CornerRadius="22"
                BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#333333}"
                TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"
                Padding="0" />
    </HorizontalStackLayout>
</ContentView>
