<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:AclsTracker"
             xmlns:converters="clr-namespace:AclsTracker.Converters"
             x:Class="AclsTracker.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converters (used by controls like TimerCard and MainPage) -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
            <converters:PauseIconConverter x:Key="PauseIconConverter" />
            <converters:BoolToActiveColorConverter x:Key="BoolToActiveColorConverter" />
            <converters:BoolToActiveTextColorConverter x:Key="BoolToActiveTextColorConverter" />
            <converters:BoolToOnOffConverter x:Key="BoolToOnOffConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>